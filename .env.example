# CourseFlix local environment
# Copy this file to .env for local development. Keep real secrets out of Git.

# Runtime
NODE_ENV=development
PORT=3000

# Web app
# Vite only exposes variables prefixed with VITE_ to browser code.
VITE_WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3000/api/v1

# API / CORS
API_BASE_PATH=/api/v1
WEB_ORIGIN=http://localhost:5173

# Database
# These values are local-only placeholders for Docker/PostgreSQL development.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=courseflix
POSTGRES_PASSWORD=courseflix_local_password
POSTGRES_DB=courseflix_dev
DATABASE_URL=postgresql://courseflix:courseflix_local_password@localhost:5432/courseflix_dev

# Auth / sessions
# Replace SESSION_SECRET in your local .env with a long random value.
SESSION_COOKIE_NAME=courseflix.sid
SESSION_SECRET=replace-with-a-long-random-local-secret
SESSION_TTL_DAYS=7
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Rate limiting
LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5

# Seed users for local demos/tests
SEED_STUDENT_EMAIL=student@courseflix.local
SEED_STUDENT_PASSWORD=Student123!
SEED_TEACHER_EMAIL=teacher@courseflix.local
SEED_TEACHER_PASSWORD=Teacher123!
